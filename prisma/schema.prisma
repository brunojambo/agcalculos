generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

enum Role {
  ADMIN
  GESTOR
  TRIADOR
  DIGITADOR
  EXECUTOR
  QUALIDADE
  FINANCEIRO
  CLIENTE
}

enum StatusProcesso {
  NOVO
  TRIAGEM
  DIGITACAO
  ELABORACAO
  REVISAO
  QUALIDADE
  AGUARDANDO_CLIENTE
  FINALIZADO
  CANCELADO
}

enum StatusFatura {
  ABERTA
  FECHADA
  PAGA
  CANCELADA
}

model Usuario {
  id        String   @id @default(cuid())
  nome      String
  email     String   @unique
  senhaHash String
  role      Role     @default(EXECUTOR)
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  processosTriagem   Processo[] @relation("Triador")
  processosDigitacao Processo[] @relation("Digitador")
  processosExecucao  Processo[] @relation("Executor")
  movimentacoes      Movimentacao[]
}

model Cliente {
  id           String   @id @default(cuid())
  razaoSocial  String
  nomeFantasia String?
  cnpj         String?
  cidade       String?
  uf           String?
  ativo        Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  contatos  ContatoCliente[]
  processos Processo[]
  faturas   Fatura[]
}

model ContatoCliente {
  id        String  @id @default(cuid())
  clienteId String
  nome      String
  email     String?
  telefone  String?
  cargo     String?

  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)
}

model TipoCalculo {
  id        String   @id @default(cuid())
  nome      String   @unique
  descricao String?
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())

  processos Processo[]
}

model Processo {
  id            String         @id @default(cuid())
  numeroCnj     String?
  reclamante    String
  reclamada     String?
  clienteId     String
  tipoCalculoId String
  status        StatusProcesso @default(NOVO)

  dataCadastro DateTime  @default(now())
  prazoInterno DateTime?
  prazoFatal   DateTime?
  dataEntrega  DateTime?

  triadorId   String?
  digitadorId String?
  executorId  String?

  valorCobrado Decimal? @db.Decimal(10, 2)
  observacao   String?

  cliente     Cliente     @relation(fields: [clienteId], references: [id])
  tipoCalculo TipoCalculo @relation(fields: [tipoCalculoId], references: [id])

  triador   Usuario? @relation("Triador", fields: [triadorId], references: [id])
  digitador Usuario? @relation("Digitador", fields: [digitadorId], references: [id])
  executor  Usuario? @relation("Executor", fields: [executorId], references: [id])

  movimentacoes Movimentacao[]
  ocorrencias   Ocorrencia[]
  anexos        Anexo[]
  faturaItens   FaturaItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([clienteId])
  @@index([prazoInterno])
}

model Movimentacao {
  id             String          @id @default(cuid())
  processoId     String
  usuarioId      String
  statusAnterior StatusProcesso?
  statusNovo     StatusProcesso
  observacao     String?
  createdAt      DateTime        @default(now())

  processo Processo @relation(fields: [processoId], references: [id], onDelete: Cascade)
  usuario  Usuario  @relation(fields: [usuarioId], references: [id])
}

model Ocorrencia {
  id          String   @id @default(cuid())
  processoId  String
  tipo        String
  descricao   String
  createdAt   DateTime @default(now())

  processo Processo @relation(fields: [processoId], references: [id], onDelete: Cascade)
}

model Anexo {
  id          String   @id @default(cuid())
  processoId  String
  nomeArquivo String
  url         String
  tipo        String?
  createdAt   DateTime @default(now())

  processo Processo @relation(fields: [processoId], references: [id], onDelete: Cascade)
}

model Fatura {
  id          String       @id @default(cuid())
  clienteId   String
  competencia String
  status      StatusFatura @default(ABERTA)
  valorTotal  Decimal?     @db.Decimal(10, 2)
  createdAt   DateTime     @default(now())

  cliente Cliente     @relation(fields: [clienteId], references: [id])
  itens   FaturaItem[]
}

model FaturaItem {
  id         String  @id @default(cuid())
  faturaId   String
  processoId String
  descricao  String
  valor      Decimal @db.Decimal(10, 2)

  fatura   Fatura   @relation(fields: [faturaId], references: [id], onDelete: Cascade)
  processo Processo @relation(fields: [processoId], references: [id])
}
